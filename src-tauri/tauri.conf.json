{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kankio",
  "version": "1.1.0",
  "identifier": "com.kankio.desktop",

  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://127.0.0.1:8000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kankio",
        "url": "https://kank.com.tr",

        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "transparent": false,

        "userAgent": "Kankio/1.1.0 (Linux; WebKitGTK)"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://kank.com.tr; connect-src 'self' https://kank.com.tr wss://kank.com.tr wss://*.livekit.cloud https://*.livekit.cloud; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://kank.com.tr https://img.youtube.com; media-src 'self' blob: https://kank.com.tr; frame-src https://www.youtube.com https://www.youtube-nocookie.com"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },

  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Kankio — Sesli Sohbet & Müzik",
    "longDescription": "Arkadaşlarınla sesli sohbet et, senkronize müzik dinle.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"],
        "section": "net",
        "priority": "optional"
      }
    },
    "resources": []
  },

  "plugins": {}
}
